# VoiceAgentRAG Configuration
# Copy to .env and fill in your values
# All variables use VOR_ prefix (Voice Optimized RAG)

# ─── LLM ───
VOR_LLM_PROVIDER=openai
VOR_LLM_MODEL=gpt-4o-mini
VOR_LLM_API_KEY=sk-your-key-here
VOR_LLM_BASE_URL=
VOR_LLM_TEMPERATURE=0.3

# ─── LLM (硅基流动 SiliconFlow) ───
# VOR_LLM_PROVIDER=siliconflow
# VOR_LLM_API_KEY=sk-your-siliconflow-key
# VOR_LLM_MODEL=deepseek-v3
# 可用简写: deepseek-v3, deepseek-r1, qwen2.5-72b, qwen2.5-7b, glm-4-9b, yi-lightning
# 或完整 ID: deepseek-ai/DeepSeek-V3, Qwen/Qwen2.5-72B-Instruct 等

# ─── Embedding ───
VOR_EMBEDDING_PROVIDER=openai
VOR_EMBEDDING_MODEL=text-embedding-3-small
VOR_EMBEDDING_DIMENSION=1536

# ─── Voice: ASR (SenseVoice) ───
VOR_STT_PROVIDER=sensevoice
VOR_SENSEVOICE_MODEL=iic/SenseVoiceSmall
VOR_SENSEVOICE_DEVICE=cuda:0

# ─── Voice: TTS (CosyVoice) ───
VOR_TTS_PROVIDER=cosyvoice
VOR_COSYVOICE_MODEL=iic/CosyVoice2-0.5B
VOR_COSYVOICE_DEVICE=cuda:0
VOR_COSYVOICE_DEFAULT_SPEAKER=中文女
VOR_COSYVOICE_REFERENCE_AUDIO=

# ─── Dialogue ───
VOR_EMOTION_ANGRY_THRESHOLD=2
VOR_MEMORY_SHORT_TERM_TURNS=10
VOR_TRANSFER_MAX_FAILURES=3

# ─── Agent ───
VOR_AGENT_MAX_ITERATIONS=10
VOR_AGENT_TOOL_TIMEOUT=3.0
VOR_AGENT_TOOL_RETRY=1

# ─── Knowledge Base ───
VOR_KB_CONFIDENCE_THRESHOLD=0.75
VOR_FAISS_INDEX_PATH=data/faiss_index

# ─── Logging ───
VOR_SESSION_LOG_DIR=logs/sessions
